# envpact ecosystem — environment variables
#
# This .env.example documents every secret the envpact monorepo
# itself needs to publish, deploy, and operate. Run
# `npx envpact-cli` from this directory to populate them into
# your private vault — the CLI will resolve shared values, prompt
# for the rest, and write a real .env (gitignored).
#
# Each token's full acquisition steps live in TOKENS.md.

# ─────────────────────────────────────────────────────────────
# Publishing — npm (envpact-cli, envpact-mcp)
# ─────────────────────────────────────────────────────────────
# https://www.npmjs.com/settings/<you>/tokens → Granular Access
# Token, scoped to envpact-cli and envpact-mcp packages.
NPM_TOKEN=

# ─────────────────────────────────────────────────────────────
# Publishing — VS Code Marketplace
# ─────────────────────────────────────────────────────────────
# Azure DevOps PAT with Marketplace:Manage scope.
# https://dev.azure.com/<your-org>/_usersSettings/tokens
VSCE_PAT=

# Optional: Open VSX mirror (VSCodium / Cursor / Theia users).
# https://open-vsx.org/user-settings/tokens
OVSX_PAT=

# ─────────────────────────────────────────────────────────────
# Deploying — Cloudflare Pages (envpact-dashboard)
# ─────────────────────────────────────────────────────────────
# https://dash.cloudflare.com/profile/api-tokens — needs
# "Cloudflare Pages: Edit" permission.
CLOUDFLARE_API_TOKEN=

# Visible on the right side of the Cloudflare dashboard home.
CLOUDFLARE_ACCOUNT_ID=

# ─────────────────────────────────────────────────────────────
# Dashboard runtime — GitHub OAuth Device Flow
# ─────────────────────────────────────────────────────────────
# Public client_id from https://github.com/settings/developers
# (Device Flow MUST be enabled). Safe to bake into the static
# bundle — there is no client secret in the device flow.
PUBLIC_GITHUB_OAUTH_CLIENT_ID=

# ─────────────────────────────────────────────────────────────
# Local tooling
# ─────────────────────────────────────────────────────────────
# Used by envpact-cli's --github sync and the umbrella
# scripts/setup-secrets.sh. The CLI auto-detects gh CLI auth
# when this is unset; only set it if you want to override.
GITHUB_TOKEN=
